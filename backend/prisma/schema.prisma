generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  medical_advisor
  admin
}

enum ArticleCategory {
  Basics
  Disorders
  Symptoms
  Treatment
}

enum SymptomSeverity {
  mild
  moderate
  severe
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  university          String?
  passwordHash        String
  gender              String?
  yearOfStudy         Int?
  department          String?
  role                Role      @default(student)
  isActive            Boolean   @default(false)
  isSuspended         Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  chatSessions        ChatSession[]
  symptomEntries      SymptomEntry[]
  bookmarks           Bookmark[]
  preferredDoctors    PreferredDoctor[]
  notifications       Notification[]
  auditLogs           AuditLog[]       @relation("AdminAuditLogs")
  passwordResets      PasswordResetToken[]

  @@map("users")
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_codes")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model ChatSession {
  id        String   @id @default(uuid())
  userId    String
  title     String?
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_sessions")
}

model SymptomEntry {
  id          String          @id @default(uuid())
  userId      String
  symptomType String
  duration    String?
  severity    SymptomSeverity
  notes       String?
  timestamp   DateTime        @default(now())

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("symptom_entries")
}

model Article {
  id             String          @id @default(uuid())
  title          String
  category       ArticleCategory
  content        String
  imageUrl       String?
  sourceCitation String?
  isApproved     Boolean         @default(false)
  reviewedBy     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  bookmarks      Bookmark[]

  @@map("articles")
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@map("bookmarks")
}

model Doctor {
  id                  String  @id @default(uuid())
  name                String
  specialization      String
  experienceYears     Int     @default(0)
  hospitalAffiliation String?
  latitude            Float?
  longitude           Float?
  phone               String?
  rating              Float?

  preferredBy         PreferredDoctor[]

  @@map("doctors")
}

model PreferredDoctor {
  id        String   @id @default(uuid())
  userId    String
  doctorId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([userId, doctorId])
  @@map("preferred_doctors")
}

model Advisor {
  id                  String  @id @default(uuid())
  name                String
  credentials         String
  hospitalAffiliation String?
  photoUrl            String?
  bio                 String?

  @@map("advisors")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())

  admin     User     @relation("AdminAuditLogs", fields: [adminId], references: [id])

  @@map("audit_logs")
}

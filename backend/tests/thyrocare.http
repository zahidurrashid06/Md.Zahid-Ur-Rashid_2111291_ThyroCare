Content-Type: application/json

{
  "messages": [
    { "role": "user", "content": "What causes fatigue?", "timestamp": "2026-04-24T00:00:00Z" },
    { "role": "assistant", "content": "Fatigue is caused by...", "timestamp": "2026-04-24T00:00:05Z" },
